{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "all_workers",
            "type": "debugpy",
            "request": "launch",
            "module": "workers.main",
            "cwd": "${workspaceFolder}/packages/workers",
            "env": {
                "WORKER_TYPE": "all"
            },
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "producer_worker",
            "type": "debugpy",
            "request": "launch",
            "module": "workers.main",
            "cwd": "${workspaceFolder}/packages/workers",
            "env": {
                "WORKER_TYPE": "producer",
                "SENSOR_ID": "F"
            },
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "justMyCode": false
